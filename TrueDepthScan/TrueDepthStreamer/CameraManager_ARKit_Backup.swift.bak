/*
See the LICENSE.txt file for this sample’s licensing information.

Abstract:
Manages the camera session and data processing via ARKit for point cloud accumulation.
*/

import Foundation
import ARKit
import CoreVideo
import UIKit
import Accelerate
import VideoToolbox

class CameraManager: NSObject, ObservableObject, ARSessionDelegate {
    
    enum SessionSetupResult {
        case success
        case notAuthorized
        case configurationFailed
    }
    
    @Published var permissionGranted = false
    @Published var sessionRunning = false
    @Published var isJetEnabled = false
    @Published var isSmoothingEnabled = false {
        didSet {
            // ARKit smoothing is handled via configuration frame semantics usually,
            // but .smoothedSceneDepth is an option on LiDAR devices.
            // For TrueDepth (FaceID), standard .sceneDepth is usually smoothed by default temporal filtering.
            // We will toggle between .sceneDepth and (if available) .smoothedSceneDepth or just rely on default.
            // Note: TrueDepth on front camera mainly supports .capturedDepthData (raw) or ARFaceTrackingConfiguration.
            // Let's stick to standard configuration updates if needed.
            restartSession()
        }
    }
    
    @Published var mixFactor: Float = 0.5 {
        didSet {
            dataOutputQueue.async {
                self.videoDepthMixer.mixFactor = self.mixFactor
            }
        }
    }
    
    // Outputs for UI
    @Published var previewPixelBuffer: CVPixelBuffer?
    @Published var capturedDepthData: AVDepthData?
    @Published var capturedVideoTexture: CVPixelBuffer?
    @Published var plyFileURL: URL?
    @Published var isScanning = false
    @Published var isCountingDown = false
    @Published var countdownValue = 0
    
    @Published var touchDepth: String = ""
    @Published var thermalState: ProcessInfo.ThermalState = .nominal
    @Published var alertMessage: AlertMessage?
    @Published var trackingStateMessage: String = "Initializing..."

    struct AlertMessage: Identifiable {
        let id = UUID()
        let title: String
        let message: String
    }
    
    private let session = ARSession()
    private let sessionQueue = DispatchQueue(label: "session queue", attributes: [], autoreleaseFrequency: .workItem)
    private var setupResult: SessionSetupResult = .success
    
    private let dataOutputQueue = DispatchQueue(label: "video data queue", qos: .userInitiated, attributes: [], autoreleaseFrequency: .workItem)
    
    private let videoDepthMixer = VideoMixer()
    private let videoDepthConverter = DepthToJETConverter()
    
    private var renderingEnabled = true
    
    // Point Cloud Accumulation
    private var accumulatedPoints: [simd_float3] = []
    private var accumulatedColors: [simd_uchar3] = []
    private var isAccumulating = false
    private let accumulationInterval = 0.1 // Seconds between accumulations
    private var lastAccumulationTime: TimeInterval = 0
    
    // Object Tracking for Continuous Multi-Angle Scanning
    private var minObservedDepth: Float = Float.greatestFiniteMagnitude  // Minimum depth seen
    private var maxObservedDepth: Float = 0.0  // Maximum depth seen
    private var previousClosestDepth: Float = 0.0  // Previous frame's closest depth
    private let maxAllowedDepthRange: Float = 0.15  // 15cm - max depth range allowed
    private let maxFrameDepthChange: Float = 0.10  // 10cm - max sudden change per frame
    private let spatialDepthTolerance: Float = 0.03  // 3cm - depth range for point filtering
    
    override init() {
        super.init()
        
        // Check video authorization status
        switch AVCaptureDevice.authorizationStatus(for: .video) {
        case .authorized:
            break
        case .notDetermined:
            sessionQueue.suspend()
            AVCaptureDevice.requestAccess(for: .video, completionHandler: { granted in
                if !granted {
                    self.setupResult = .notAuthorized
                }
                self.sessionQueue.resume()
            })
        default:
            setupResult = .notAuthorized
        }
        
        session.delegate = self
        
        addObservers()
    }
    
    deinit {
        NotificationCenter.default.removeObserver(self)
        session.pause()
    }
    
    func startSession() {
        sessionQueue.async {
            switch self.setupResult {
            case .success:
                self.restartSession()
                DispatchQueue.main.async {
                    self.permissionGranted = true
                }
            case .notAuthorized:
                DispatchQueue.main.async {
                    self.permissionGranted = false
                    self.alertMessage = AlertMessage(title: "TrueDepthStreamer",
                                                     message: "TrueDepthStreamer doesn't have permission to use the camera, please change privacy settings")
                }
            case .configurationFailed:
                DispatchQueue.main.async {
                    self.alertMessage = AlertMessage(title: "TrueDepthStreamer",
                                                     message: "Unable to capture media")
                }
            }
        }
    }
    
    func stopSession() {
        sessionQueue.async {
            self.session.pause()
            DispatchQueue.main.async {
                self.sessionRunning = false
            }
        }
    }
    
    private func restartSession() {
        guard ARFaceTrackingConfiguration.isSupported else {
            DispatchQueue.main.async {
                self.alertMessage = AlertMessage(
                    title: "Not Supported", 
                    message: "Face Tracking (TrueDepth) is not supported on this device. This app requires an iPhone X or newer with Face ID."
                )
                self.sessionRunning = false
            }
            return
        }
        
        let configuration = ARFaceTrackingConfiguration()
        // ARFaceTrackingConfiguration uses the Front TrueDepth Camera.
        // It provides .capturedDepthData.
        // Note: It does not support World Tracking (Translation), so accumulation will rely on Rotation (3DOF) only.
        // If the user wants 6DOF scanning, they need a LiDAR device and Rear Camera, but this app is "TrueDepthStreamer".
        
        // Reset accumulation
        accumulatedPoints.removeAll()
        accumulatedColors.removeAll()
        
        session.run(configuration, options: [.resetTracking, .removeExistingAnchors])
        
        DispatchQueue.main.async {
            self.sessionRunning = true
        }
    }
    
    // MARK: - Scanning Logic
    
    func startCountdown() {
        isCountingDown = true
        countdownValue = 3
        
        Timer.scheduledTimer(withTimeInterval: 1.0, repeats: true) { timer in
            if self.countdownValue > 1 {
                self.countdownValue -= 1
            } else {
                timer.invalidate()
                self.isCountingDown = false
                self.startScanning()
            }
        }
    }
    
    private func startScanning() {
        // Reset buffer
        accumulatedPoints.removeAll()
        accumulatedColors.removeAll()
        
        // Reset dynamic depth range tracking
        minObservedDepth = Float.greatestFiniteMagnitude
        maxObservedDepth = 0.0
        previousClosestDepth = 0.0
        
        isScanning = true
        isAccumulating = true
    }
    
    
    func stopScanning() {
        if isScanning {
            isScanning = false
            isAccumulating = false
            
            // Automatically save and show results
            DispatchQueue.global(qos: .userInitiated).async {
                if let url = self.saveAccumulatedPLY() {
                    DispatchQueue.main.async {
                        self.plyFileURL = url
                    }
                }
            }
        }
    }
    
    func resetScan() {
        capturedDepthData = nil
        capturedVideoTexture = nil
        plyFileURL = nil
        accumulatedPoints.removeAll()
        accumulatedColors.removeAll()
    }
    
    // MARK: - ARSessionDelegate
    
    func session(_ session: ARSession, didUpdate frame: ARFrame) {
        // 1. Update Tracking Status for UI
        updateTrackingState(frame.camera)
        
        // 2. Check Tracking for Scanning
        if isScanning {
            if frame.camera.trackingState == .normal {
                // Good to accumulate
            } else {
                // Tracking lost or limited - Stop scanning to prevent bad data
                DispatchQueue.main.async {
                    self.stopScanning()
                    self.alertMessage = AlertMessage(title: "Scanning Stopped", message: "Tracking lost. Please move slower.")
                }
                return
            }
        }
        
        // 3. Process Depth & Video for Preview
        // Note: For ARFaceTrackingConfiguration, use capturedDepthData.
        guard let depthData = frame.capturedDepthData else {
            // Debug: If depth is missing, print
            print("⚠️ Depth data missing in frame")
            return
        }
        
        // Debug: Confirm depth data is being received
        print("✅ Received depth data: \(CVPixelBufferGetWidth(depthData.depthDataMap))x\(CVPixelBufferGetHeight(depthData.depthDataMap))")
        
        let pixelBuffer = frame.capturedImage
        let depthBuffer = depthData.depthDataMap
        
        // Orientation adjustment might be needed. ARKit frames are usually LandscapeRight.
        // We pass raw buffers to the mixer.
        
        if isJetEnabled {
            processPreview(depthBuffer: depthBuffer, videoBuffer: pixelBuffer)
        }
        
        // 4. Accumulate Points
        if isAccumulating {
            let currentTime = frame.timestamp
            if currentTime - lastAccumulationTime > accumulationInterval {
                lastAccumulationTime = currentTime
                accumulatePoints(frame: frame)
            }
        }
    }
    
    private func updateTrackingState(_ camera: ARCamera) {
        var message = ""
        switch camera.trackingState {
        case .normal:
            message = "Tracking: Good"
        case .notAvailable:
            message = "Tracking: Not Available"
        case .limited(let reason):
            switch reason {
            case .excessiveMotion:
                message = "Tracking Limited: Too fast"
            case .insufficientFeatures:
                message = "Tracking Limited: Low detail"
            case .initializing:
                message = "Tracking: Initializing..."
            case .relocalizing:
                message = "Tracking: Relocalizing..."
            @unknown default:
                message = "Tracking Limited"
            }
        }
        
        DispatchQueue.main.async {
            self.trackingStateMessage = message
        }
    }
    
    // MARK: - Point Cloud Accumulation
    
    private func accumulatePoints(frame: ARFrame) {
        guard let depthData = frame.capturedDepthData else { return }
        let depthBuffer = depthData.depthDataMap
        let videoBuffer = frame.capturedImage
        let camera = frame.camera
        let transform = camera.transform // Camera to World
        let intrinsics = camera.intrinsics
        
        CVPixelBufferLockBaseAddress(depthBuffer, .readOnly)
        CVPixelBufferLockBaseAddress(videoBuffer, .readOnly)
        defer {
            CVPixelBufferUnlockBaseAddress(depthBuffer, .readOnly)
            CVPixelBufferUnlockBaseAddress(videoBuffer, .readOnly)
        }
        
        let width = CVPixelBufferGetWidth(depthBuffer)
        let height = CVPixelBufferGetHeight(depthBuffer)
        
        guard let depthBase = CVPixelBufferGetBaseAddress(depthBuffer),
              let videoBase = CVPixelBufferGetBaseAddress(videoBuffer) else { return }
        
        let depthBytesPerRow = CVPixelBufferGetBytesPerRow(depthBuffer)
        let videoBytesPerRow = CVPixelBufferGetBytesPerRow(videoBuffer)
        let videoWidth = CVPixelBufferGetWidth(videoBuffer)
        let videoHeight = CVPixelBufferGetHeight(videoBuffer)
        
        // CRITICAL FIX: Scale intrinsics to depth buffer resolution
        // Camera intrinsics are calibrated for video frame, but we're using depth buffer coordinates
        let videoIntrinsics = camera.intrinsics
        let scaleX = Float(width) / Float(videoWidth)
        let scaleY = Float(height) / Float(videoHeight)
        
        let fx = videoIntrinsics[0][0] * scaleX
        let fy = videoIntrinsics[1][1] * scaleY
        let cx = videoIntrinsics[2][0] * scaleX
        let cy = videoIntrinsics[2][1] * scaleY
        
        // Debug logging (first frame only)
        if minObservedDepth == Float.greatestFiniteMagnitude {
            print("🔍 Depth buffer: \(width)x\(height)")
            print("🔍 Video buffer: \(videoWidth)x\(videoHeight)")
            print("🔍 Scale factors: X=\(scaleX), Y=\(scaleY)")
            print("🔍 Original intrinsics: fx=\(videoIntrinsics[0][0]), fy=\(videoIntrinsics[1][1])")
            print("🔍 Scaled intrinsics: fx=\(fx), fy=\(fy), cx=\(cx), cy=\(cy)")
        }
        
        // Step 1: Find the CLOSEST object (minimum depth) in current frame
        var validDepths: [Float] = []
        let sampleStride = 4
        
        for y in stride(from: 0, to: height, by: sampleStride) {
            let depthRow = depthBase.advanced(by: y * depthBytesPerRow).assumingMemoryBound(to: Float16.self)
            
            for x in stride(from: 0, to: width, by: sampleStride) {
                var depthFloat: Float = 0.0
                var depth16 = depthRow[x]
                
                var src = depth16
                withUnsafePointer(to: &src) { srcPtr in
                    var srcBuffer = vImage_Buffer(data: UnsafeMutableRawPointer(mutating: srcPtr), height: 1, width: 1, rowBytes: 2)
                    var dstBuffer = vImage_Buffer(data: &depthFloat, height: 1, width: 1, rowBytes: 4)
                    vImageConvert_Planar16FtoPlanarF(&srcBuffer, &dstBuffer, 0)
                }
                
                // Only consider valid TrueDepth range
                if depthFloat > 0.10 && depthFloat < 0.60 {
                    validDepths.append(depthFloat)
                }
            }
        }
        
        guard !validDepths.isEmpty else {
            print("⚠️ No valid depth data in frame")
            return
        }
        
        // Find minimum depth (closest object) THIS frame
        let minDepth = validDepths.min()!
        let nearMinDepths = validDepths.filter { abs($0 - minDepth) < 0.02 }
        let currentClosestDepth = nearMinDepths.isEmpty ? minDepth : nearMinDepths.sorted()[nearMinDepths.count / 2]
        
        // Step 2: Update dynamic depth range
        if minObservedDepth == Float.greatestFiniteMagnitude {
            // First frame - initialize
            minObservedDepth = currentClosestDepth
            maxObservedDepth = currentClosestDepth
            previousClosestDepth = currentClosestDepth
            print("✅ Started scanning at: \(String(format: "%.2f", currentClosestDepth * 100))cm")
        } else {
            // Check for sudden depth change (object replaced or disappeared)
            let frameChange = abs(currentClosestDepth - previousClosestDepth)
            if frameChange > maxFrameDepthChange {
                print("✅ Scan complete - Object changed: \(String(format: "%.1f", frameChange * 100))cm sudden change")
                DispatchQueue.main.async {
                    self.stopScanning()
                }
                return
            }
            
            // Update observed depth range
            minObservedDepth = min(minObservedDepth, currentClosestDepth)
            maxObservedDepth = max(maxObservedDepth, currentClosestDepth)
            
            // Check if total depth range is too large (object moved too far)
            let depthRange = maxObservedDepth - minObservedDepth
            if depthRange > maxAllowedDepthRange {
                print("✅ Scan complete - Object moved too far: \(String(format: "%.1f", depthRange * 100))cm range")
                DispatchQueue.main.async {
                    self.stopScanning()
                }
                return
            }
            
            previousClosestDepth = currentClosestDepth
        }
        
        // Step 3: Accumulate points within spatial tolerance of CURRENT closest depth
        // This allows capturing different surfaces as object rotates
        for y in stride(from: 0, to: height, by: sampleStride) {
            let depthRow = depthBase.advanced(by: y * depthBytesPerRow).assumingMemoryBound(to: Float16.self)
            
            for x in stride(from: 0, to: width, by: sampleStride) {
                var depthFloat: Float = 0.0
                var depth16 = depthRow[x]
                
                var src = depth16
                withUnsafePointer(to: &src) { srcPtr in
                    var srcBuffer = vImage_Buffer(data: UnsafeMutableRawPointer(mutating: srcPtr), height: 1, width: 1, rowBytes: 2)
                    var dstBuffer = vImage_Buffer(data: &depthFloat, height: 1, width: 1, rowBytes: 4)
                    vImageConvert_Planar16FtoPlanarF(&srcBuffer, &dstBuffer, 0)
                }
                
                // Accumulate points within ±3cm of current closest depth
                if abs(depthFloat - currentClosestDepth) < spatialDepthTolerance {
                    // 1. Unproject to Camera Space
                    let x_cv = (Float(x) - cx) * depthFloat / fx
                    let y_cv = (Float(y) - cy) * depthFloat / fy
                    let z_cv = depthFloat
                    
                    // 2. Convert to ARKit Camera Space (Y-up, Z-back)
                    // For object scanning, we keep points in CAMERA SPACE (not world space)
                    // This ensures points from different angles align properly
                    let cameraPoint = simd_float3(x_cv, -y_cv, -z_cv)
                    
                    // Debug: Log first point for verification
                    if accumulatedPoints.isEmpty {
                        print("🎯 First point sample:")
                        print("   Pixel: (\(x), \(y)), Depth: \(String(format: "%.3f", depthFloat))m")
                        print("   Camera space: (\(String(format: "%.3f", x_cv)), \(String(format: "%.3f", y_cv)), \(String(format: "%.3f", z_cv)))")
                        print("   Final point: (\(String(format: "%.3f", cameraPoint.x)), \(String(format: "%.3f", cameraPoint.y)), \(String(format: "%.3f", cameraPoint.z)))")
                    }
                    
                    // 3. Get Color
                    let vX = Int(Float(x) / Float(width) * Float(videoWidth))
                    let vY = Int(Float(y) / Float(height) * Float(videoHeight))
                    
                    var color = simd_uchar3(255, 255, 255)
                    
                    if vX >= 0 && vX < videoWidth && vY >= 0 && vY < videoHeight {
                        let pixelOffset = vY * videoBytesPerRow + vX
                        let luma = videoBase.load(fromByteOffset: pixelOffset, as: UInt8.self)
                        color = simd_uchar3(luma, luma, luma)
                    }
                    
                    // Store camera-relative points (not world space)
                    accumulatedPoints.append(cameraPoint)
                    accumulatedColors.append(color)
                }
            }
        }
        
        let depthRange = maxObservedDepth - minObservedDepth
        print("📊 Points: \(accumulatedPoints.count), Current: \(String(format: "%.2f", currentClosestDepth * 100))cm, Range: \(String(format: "%.1f", depthRange * 100))cm")
    }
    
    private func saveAccumulatedPLY() -> URL? {
        guard !accumulatedPoints.isEmpty else {
            print("❌ No points to save")
            return nil
        }
        
        // Validate point cloud bounds
        let xs = accumulatedPoints.map { $0.x }
        let ys = accumulatedPoints.map { $0.y }
        let zs = accumulatedPoints.map { $0.z }
        
        let minX = xs.min()! * 1000  // Convert to mm
        let maxX = xs.max()! * 1000
        let minY = ys.min()! * 1000
        let maxY = ys.max()! * 1000
        let minZ = zs.min()! * 1000
        let maxZ = zs.max()! * 1000
        
        print("📦 Point cloud bounds (mm):")
        print("   X: [\(String(format: "%.1f", minX)), \(String(format: "%.1f", maxX))] range: \(String(format: "%.1f", maxX - minX))mm")
        print("   Y: [\(String(format: "%.1f", minY)), \(String(format: "%.1f", maxY))] range: \(String(format: "%.1f", maxY - minY))mm")
        print("   Z: [\(String(format: "%.1f", minZ)), \(String(format: "%.1f", maxZ))] range: \(String(format: "%.1f", maxZ - minZ))mm")
        
        var lines: [String] = []
        
        // PLY Header
        lines.append("ply")
        lines.append("format ascii 1.0")
        lines.append("element vertex \(accumulatedPoints.count)")
        lines.append("property float x")
        lines.append("property float y")
        lines.append("property float z")
        lines.append("property uchar red")
        lines.append("property uchar green")
        lines.append("property uchar blue")
        lines.append("end_header")
        
        for i in 0..<accumulatedPoints.count {
            let p = accumulatedPoints[i]
            // Scale to Millimeters (standard for many 3D apps)
            let x = p.x * 1000
            let y = p.y * 1000
            let z = p.z * 1000
            let c = accumulatedColors[i]
            lines.append("\(x) \(y) \(z) \(c.x) \(c.y) \(c.z)")
        }
        
        let fileContent = lines.joined(separator: "\n")
        let fileName = "scan_\(Date().timeIntervalSince1970).ply"
        let fileURL = FileManager.default.temporaryDirectory.appendingPathComponent(fileName)
        
        do {
            try fileContent.write(to: fileURL, atomically: true, encoding: .ascii)
            return fileURL
        } catch {
            print("Failed to save PLY: \(error)")
            return nil
        }
    }
    
    // MARK: - Preview Logic
    
    private func processPreview(depthBuffer: CVPixelBuffer, videoBuffer: CVPixelBuffer) {
        if !videoDepthConverter.isPrepared {
            // Validate depth buffer format before preparing
            let depthFormat = CVPixelBufferGetPixelFormatType(depthBuffer)
            print("🔍 Depth buffer format: \(depthFormat) (expected: \(kCVPixelFormatType_DepthFloat16) or \(kCVPixelFormatType_DepthFloat32))")
            
            // ARKit depth should be kCVPixelFormatType_DepthFloat32 (1717855600) or Float16 (1717855344)
            if depthFormat != kCVPixelFormatType_DepthFloat16 && depthFormat != kCVPixelFormatType_DepthFloat32 {
                print("❌ Unsupported depth format: \(depthFormat)")
                return
            }
            
            var depthFormatDescription: CMFormatDescription?
            CMVideoFormatDescriptionCreateForImageBuffer(allocator: kCFAllocatorDefault,
                                                         imageBuffer: depthBuffer,
                                                         formatDescriptionOut: &depthFormatDescription)
            if let desc = depthFormatDescription {
                videoDepthConverter.prepare(with: desc, outputRetainedBufferCountHint: 2)
            } else {
                print("❌ Failed to create depth format description")
                return
            }
        }
        
        guard let jetPixelBuffer = videoDepthConverter.render(pixelBuffer: depthBuffer) else { return }
        
        // Convert YCbCr (ARKit) to BGRA for Mixing
        // ARKit video is kCVPixelFormatType_420YpCbCr8BiPlanarFullRange
        // VideoMixer expects BGRA.
        var bgraVideoBuffer: CVPixelBuffer?
        if let converted = convertYCbCrToBGRA(videoBuffer) {
            bgraVideoBuffer = converted
        } else {
            // Fallback: If conversion fails, maybe it's already BGRA or we skip mixing
             bgraVideoBuffer = videoBuffer
        }
        
        guard let finalVideoBuffer = bgraVideoBuffer else { return }
        
        if !videoDepthMixer.isPrepared {
            var videoFormatDescription: CMFormatDescription?
            CMVideoFormatDescriptionCreateForImageBuffer(allocator: kCFAllocatorDefault,
                                                         imageBuffer: finalVideoBuffer,
                                                         formatDescriptionOut: &videoFormatDescription)
            if let desc = videoFormatDescription {
                videoDepthMixer.prepare(with: desc, outputRetainedBufferCountHint: 3)
            }
        }
        
        guard let mixedBuffer = videoDepthMixer.mix(videoPixelBuffer: finalVideoBuffer, depthPixelBuffer: jetPixelBuffer) else { return }
        
        DispatchQueue.main.async {
            self.previewPixelBuffer = mixedBuffer
        }
        
        // Touch depth logic...
        processDepthAtTouch(depthFrame: depthBuffer, videoFrame: videoBuffer)
    }
    
    private var pixelTransferSession: VTPixelTransferSession?
    
    private func convertYCbCrToBGRA(_ sourceBuffer: CVPixelBuffer) -> CVPixelBuffer? {
        let format = CVPixelBufferGetPixelFormatType(sourceBuffer)
        if format == kCVPixelFormatType_32BGRA { return sourceBuffer }
        
        // Lazy init session
        if pixelTransferSession == nil {
             VTPixelTransferSessionCreate(allocator: kCFAllocatorDefault, pixelTransferSessionOut: &pixelTransferSession)
        }
        
        guard let session = pixelTransferSession else { return nil }
        
        let width = CVPixelBufferGetWidth(sourceBuffer)
        let height = CVPixelBufferGetHeight(sourceBuffer)
        
        var destBuffer: CVPixelBuffer?
        let attrs: [String: Any] = [
            kCVPixelBufferIOSurfacePropertiesKey as String: [:]
        ]
        
        let status = CVPixelBufferCreate(kCFAllocatorDefault, width, height, kCVPixelFormatType_32BGRA, attrs as CFDictionary, &destBuffer)
        
        if status == kCVReturnSuccess, let dest = destBuffer {
            VTSessionSetProperty(session, key: kVTPixelTransferPropertyKey_ScalingMode, value: kVTScalingMode_Normal)
            if VTPixelTransferSessionTransferImage(session, from: sourceBuffer, to: dest) == kCVReturnSuccess {
                return dest
            }
        }
        
        return nil
    }
    
    // MARK: - Depth Measurement Helper
    
    func setTouchCoordinates(_ point: CGPoint, detected: Bool) {
        dataOutputQueue.async {
            self.touchDetected = detected
            self.touchCoordinates = point
        }
        if !detected {
            DispatchQueue.main.async { self.touchDepth = "" }
        }
    }
    
    private var touchDetected = false
    private var touchCoordinates: CGPoint = .zero
    var textureTransformResolver: ((CGPoint) -> CGPoint?)?
    
    private func processDepthAtTouch(depthFrame: CVPixelBuffer, videoFrame: CVPixelBuffer) {
        guard touchDetected, let resolve = textureTransformResolver, let texturePoint = resolve(touchCoordinates) else { return }
        
        let depthWidth = CVPixelBufferGetWidth(depthFrame)
        let depthHeight = CVPixelBufferGetHeight(depthFrame)
        let videoWidth = CVPixelBufferGetWidth(videoFrame)
        let videoHeight = CVPixelBufferGetHeight(videoFrame)
        
        // Map texture coordinates directly to depth buffer coordinates
        // Assuming both buffers have the same aspect ratio and orientation
        let depthX = Int(texturePoint.x * CGFloat(depthWidth) / CGFloat(videoWidth))
        let depthY = Int(texturePoint.y * CGFloat(depthHeight) / CGFloat(videoHeight))
        
        // Clamp to valid range
        let clampedX = max(0, min(depthWidth - 1, depthX))
        let clampedY = max(0, min(depthHeight - 1, depthY))
        
        CVPixelBufferLockBaseAddress(depthFrame, .readOnly)
        defer { CVPixelBufferUnlockBaseAddress(depthFrame, .readOnly) }
        
        guard let baseAddress = CVPixelBufferGetBaseAddress(depthFrame) else { return }
        let rowData = baseAddress + clampedY * CVPixelBufferGetBytesPerRow(depthFrame)
        var f16Pixel = rowData.assumingMemoryBound(to: UInt16.self)[clampedX]
        var f32Pixel = Float(0.0)
        
        withUnsafeMutablePointer(to: &f16Pixel) { src in
            withUnsafeMutablePointer(to: &f32Pixel) { dst in
                var s = vImage_Buffer(data: src, height: 1, width: 1, rowBytes: 2)
                var d = vImage_Buffer(data: dst, height: 1, width: 1, rowBytes: 4)
                vImageConvert_Planar16FtoPlanarF(&s, &d, 0)
            }
        }
        
        // Debug logging
        print("📍 Touch: (\(Int(touchCoordinates.x)), \(Int(touchCoordinates.y))) -> Texture: (\(Int(texturePoint.x)), \(Int(texturePoint.y))) -> Depth: (\(clampedX), \(clampedY)) = \(f32Pixel)m")
        
        // Convert from meters to centimeters for display
        // Apple provides depth in meters, multiply by 100 for cm
        let depthString = String(format: "%.2f cm", f32Pixel * 100.0)
        DispatchQueue.main.async {
            self.touchDepth = depthString
        }
    }
    
    // MARK: - Notifications
    
    private func addObservers() {
        NotificationCenter.default.addObserver(self, selector: #selector(thermalStateChanged),
                                               name: ProcessInfo.thermalStateDidChangeNotification, object: nil)
    }
    
    @objc func thermalStateChanged(notification: NSNotification) {
        if let processInfo = notification.object as? ProcessInfo {
            DispatchQueue.main.async {
                self.thermalState = processInfo.thermalState
            }
        }
    }
}
